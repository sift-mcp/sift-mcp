[0.003228, "o", "\u001b[H\u001b[2J\u001b[3J"]
[0.003496, "o", "=== Connecting Sift to Claude Code ===\r\n\r\n"]
[2.004223, "o", "Step 1: Add Sift as an MCP server\r\n\r\n"]
[2.004273, "o", "c"]
[2.035591, "o", "l"]
