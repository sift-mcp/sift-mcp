[0.003714, "o", "\u001b[H\u001b[2J"]
[0.00402, "o", "=== Connecting Sift to Claude Code ===\r\n\r\n"]
[2.006349, "o", "Step 1: Add Sift as an MCP server\r\n\r\nc"]
[2.037116, "o", "l"]
[2.068765, "o", "a"]
[2.10047, "o", "u"]
